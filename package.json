{
  "name": "nomad-calc-module",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/nomad-calc-module.umd.cjs",
  "module": "./dist/nomad-calc-module.js",
  "types": "./dist/nomad-calc-module.d.ts",
  "exports": {
    ".": {
      "types": "./dist/nomad-calc-module.d.ts",
      "import": "./dist/nomad-calc-module.js",
      "require": "./dist/nomad-calc-module.umd.cjs"
    },
    "./dist/nomad-calc-module.css": "./dist/nomad-calc-module.css"
  },
  "scripts": {
    "dev": "vite dev --host",
    "build": "vue-tsc -b && vite build --config vite.config.ts && vite build --config vite.config.ce.ts",
    "build:ce": "vue-tsc -b && vite build --config vite.config.ce.ts",
    "preview": "vite preview",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@iconify-json/ri": "^1.2.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.1.4"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.92.9",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "maska": "^3.2.0",
    "nomad-api-sdk": "git+ssh://git@gitlab-01.nomad.kz/root/nomad-gateway-api-typescript-sdk.git#1.2.36",
    "nomad-ui": "git+ssh://git@gitlab-01.nomad.kz/nomad-web/nomad-ui.git#ui-0.1.3",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue-toastification": "^2.0.0-rc.5",
    "yup": "^1.7.1"
  }
}
